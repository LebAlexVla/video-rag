{
  "Qdrant": {
    "BaseUrl": "http://localhost:6333",
    "CollectionName": "lecture-chunks",
    "VectorSize": 768,
    "Distance": "Cosine"
  },
  "Embeddings": {
    "Provider": "gemini",
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "Model": "embeddinggemma"
    },
    "OpenAi": {
      "BaseUrl": "https://api.openai.com",
      "ApiKey": "",
      "Model": "text-embedding-3-small"
    },
    "Gemini": {
      "BaseUrl": "https://generativelanguage.googleapis.com",
      "ApiKey": "",
      "Model": "gemini-embedding-001",
      "OutputDimensionality": 768
    }
  },
  "Answers": {
    "Provider": "deepseek",
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "Model": "llama3.1"
    },
    "OpenAi": {
      "BaseUrl": "https://api.openai.com",
      "ApiKey": "",
      "Model": "gpt-4o-mini"
    },
    "DeepSeek": {
      "BaseUrl": "https://api.deepseek.com",
      "ApiKey": "",
      "Model": "deepseek-v4-flash"
    },
    "Yandex": {
      "BaseUrl": "https://ai.api.cloud.yandex.net/v1",
      "ApiKey": "",
      "FolderId": "",
      "Model": "deepseek-v32"
    }
  },
  "Chunking": {
    "MaxChunkLength": 1200,
    "OverlapLength": 200
  },
  "Paths": {
    "Videos": "data/videos",
    "Transcripts": "data/transcripts",
    "Jobs": "data/jobs",
    "Registry": "data/registry/lectures.json"
  },
  "PythonHelper": {
    "PythonExecutable": "python",
    "ScriptPath": "scripts/python-helper/main.py"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "AudioDownloader": {
    "ExecutablePath": "yt-dlp",
    "OutputDirectory": "data/downloads/audio",
    "Format": "bestaudio/worst[acodec!=none]",
    "AudioFormat": "m4a",
    "AudioQuality": "0",
    "NoPlaylist": true,
    "FfmpegExecutablePath": "ffmpeg",
    "UseStreamingFfmpegCopy": true,
    "FallbackToYtDlpPostProcessing": true
  }
}