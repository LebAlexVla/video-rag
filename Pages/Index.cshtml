@page
@model VideoLectureRagAssistant.Pages.IndexModel

@{
    ViewData["Title"] = "Video Lecture RAG Assistant";
}

<!doctype html>
<html lang="ru">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>@ViewData["Title"]</title>

    <style>
        :root {
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            color: #111827;
            background: #f3f4f6;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 32px;
        }

        .page {
            max-width: 960px;
            margin: 0 auto;
        }

        .header {
            margin-bottom: 24px;
        }

        .header h1 {
            margin: 0 0 8px;
            font-size: 28px;
        }

        .header p {
            margin: 0;
            color: #6b7280;
        }

        .card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 16px;
            padding: 20px;
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
            margin-bottom: 20px;
        }

        label {
            display: block;
            font-weight: 600;
            margin-bottom: 8px;
        }

        textarea,
        input {
            width: 100%;
            border: 1px solid #d1d5db;
            border-radius: 10px;
            padding: 12px;
            font: inherit;
            background: #ffffff;
        }

        textarea {
            min-height: 110px;
            resize: vertical;
        }

        .row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-top: 16px;
        }

        .actions {
            display: flex;
            gap: 12px;
            align-items: center;
            margin-top: 16px;
        }

        button {
            border: 0;
            border-radius: 10px;
            padding: 12px 18px;
            font: inherit;
            font-weight: 600;
            cursor: pointer;
            background: #2563eb;
            color: white;
        }

        .answer {
            white-space: pre-wrap;
            line-height: 1.55;
        }

        .fallback {
            color: #92400e;
            background: #fffbeb;
            border: 1px solid #fde68a;
            padding: 12px;
            border-radius: 10px;
        }

        .error {
            color: #991b1b;
            background: #fef2f2;
            border: 1px solid #fecaca;
            padding: 12px;
            border-radius: 10px;
            white-space: pre-wrap;
        }

        .sources {
            margin-top: 16px;
        }

        .source {
            padding: 12px;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            margin-top: 8px;
            background: #f9fafb;
        }

        .source-title {
            font-weight: 700;
            margin-bottom: 4px;
        }

        .source-meta {
            color: #6b7280;
            font-size: 14px;
        }

        .validation {
            color: #991b1b;
            margin-top: 8px;
        }

        @@media (max-width: 720px) {
            body {
                padding: 16px;
            }

            .row {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
<div class="page">
    <div class="header">
        <h1>Video Lecture RAG Assistant</h1>
        <p>Razor UI для тестирования вопросов по проиндексированным лекциям.</p>
    </div>

    <div class="card">
        <form method="post">
            @Html.AntiForgeryToken()

            <label asp-for="Input.Question">Вопрос</label>
            <textarea asp-for="Input.Question" placeholder="Например: О чём эта лекция?"></textarea>
            <span asp-validation-for="Input.Question" class="validation"></span>

            <div class="row">
                <div>
                    <label asp-for="Input.TopK">TopK</label>
                    <input asp-for="Input.TopK" type="number" min="1" max="10"/>
                    <span asp-validation-for="Input.TopK" class="validation"></span>
                </div>

                <div>
                    <label asp-for="Input.MinScore">MinScore</label>
                    <input asp-for="Input.MinScore" type="number" min="0" max="1" step="0.05"/>
                    <span asp-validation-for="Input.MinScore" class="validation"></span>
                </div>
            </div>

            <div class="actions">
                <button type="submit">Спросить</button>
            </div>
        </form>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="card">
            <h2>Ошибка</h2>
            <div class="error">@Model.ErrorMessage</div>
        </div>
    }

    @if (Model.AskResponse is not null)
    {
        <div class="card">
            <h2>Ответ</h2>

            @if (!Model.AskResponse.UsedContext)
            {
                <div class="fallback">
                    @(Model.AskResponse.Message ?? "Недостаточно релевантного контекста для ответа.")
                </div>
            }
            else
            {
                <div class="answer">@Model.AskResponse.Answer</div>

                @if (Model.AskResponse.Sources.Count > 0)
                {
                    <div class="sources">
                        <h3>Источники</h3>

                        @foreach (var source in Model.AskResponse.Sources)
                        {
                            <div class="source">
                                <div class="source-title">@source.LectureTitle</div>
                                <div class="source-meta">
                                    chunk: @source.ChunkIndex;
                                    @if (source.ApproxStartSec.HasValue && source.ApproxEndSec.HasValue)
                                    {
                                        <span>
                                            примерно @FormatSeconds(source.ApproxStartSec.Value)–@FormatSeconds(source.ApproxEndSec.Value)
                                        </span>
                                    }
                                    else
                                    {
                                        <span>
                                            примерно @source.ApproxMinute мин.
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    }
</div>
</body>
</html>

@functions {
    private static string FormatSeconds(double value)
    {
        var total = (int)Math.Floor(value);
        var minutes = total / 60;
        var seconds = total % 60;

        return $"{minutes}:{seconds:D2}";
    }
}