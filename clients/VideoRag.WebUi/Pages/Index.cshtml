@page
@model VideoRag.WebUi.Pages.IndexModel

@{
    ViewData["Title"] = "Video Lecture RAG Assistant";
}

<div class="shell">
    <header class="topbar">
        <div class="brand-block">
            <div class="brand-badge">AI • RAG • Lectures</div>
            <h1>Video Lecture RAG Assistant</h1>
            <p class="subtitle">
                Добавляй лекции по Rutube/VK-ссылкам, отслеживай обработку и задавай вопросы.
            </p>
        </div>

        <div class="topbar-actions">
            @if (Model.IsApiHealthy == true)
            {
                <div class="status-pill status-pill-ok">
                    <span class="status-dot"></span>
                    API доступен
                </div>
            }
            else if (Model.IsApiHealthy == false)
            {
                <div class="status-pill status-pill-bad">
                    <span class="status-dot"></span>
                    API недоступен
                </div>
            }
            else
            {
                <div class="status-pill">
                    <span class="status-dot"></span>
                    Проверка API...
                </div>
            }
        </div>
    </header>

    <main class="main-grid">
        <section class="panel glass-panel">
            <div class="panel-header">
                <h2>Добавить лекцию по ссылке</h2>
                <p>После отправки появится UUID задачи. Статус будет обновляться автоматически.</p>
            </div>

            <form method="post" asp-page-handler="StartUrlIngest" class="ask-form">
                <div class="field">
                    <label for="UrlInput_Url">Rutube / VK URL</label>
                    <input id="UrlInput_Url" name="UrlInput.Url" value="@Model.UrlInput.Url" placeholder="https://rutube.ru/video/... или https://vkvideo.ru/video..." />
                </div>

                <div class="field">
                    <label for="UrlInput_LectureTitle">Название лекции</label>
                    <input id="UrlInput_LectureTitle" name="UrlInput.LectureTitle" value="@Model.UrlInput.LectureTitle" placeholder="Например: Лекция по физике" />
                    <div class="hint">Необязательно, но так проще потом искать источник.</div>
                </div>

                <div class="params-grid">
                    <div class="field">
                        <label for="UrlInput_LanguageHint">Язык</label>
                        <input id="UrlInput_LanguageHint" name="UrlInput.LanguageHint" value="@Model.UrlInput.LanguageHint" placeholder="ru" />
                    </div>

                    <div class="field">
                        <label for="UrlInput_TranscriptionModel">Whisper model</label>
                        <input id="UrlInput_TranscriptionModel" name="UrlInput.TranscriptionModel" value="@Model.UrlInput.TranscriptionModel" placeholder="tiny / base / small" />
                        <div class="hint">Для быстрых тестов можно указать tiny или base.</div>
                    </div>
                </div>

                <input type="hidden" name="UrlInput.TranscriptionProvider" value="@Model.UrlInput.TranscriptionProvider" />

                <div class="submit-row">
                    <button type="submit" class="primary-btn">Добавить лекцию</button>
                </div>
            </form>

            <div class="tips-card">
                <div class="tips-title">Проверить статус по UUID</div>

                <form method="post" asp-page-handler="CheckUrlIngestStatus" class="ask-form">
                    <div class="field">
                        <label for="StatusJobId">Job UUID</label>
                        <input id="StatusJobId" name="StatusJobId" value="@Model.StatusJobId" placeholder="UUID задачи после отправки ссылки" />
                    </div>

                    <div class="submit-row">
                        <button type="submit" class="primary-btn">Проверить статус</button>
                    </div>
                </form>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.IngestErrorMessage))
            {
                <div class="message-box message-error">
                    <div class="message-title">Ошибка обработки</div>
                    <div>@Model.IngestErrorMessage</div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.IngestInfoMessage))
            {
                <div class="message-box message-warning">
                    <div class="message-title">Статус</div>
                    <div>@Model.IngestInfoMessage</div>
                </div>
            }

            @if (Model.IngestStartResponse is not null || Model.IngestJobStatus is not null)
            {
                var currentJobId = Model.IngestJobStatus?.JobId
                    ?? Model.IngestStartResponse?.JobId
                    ?? Guid.Empty;

                <div
                    id="url-ingest-status"
                    class="message-box message-warning"
                    data-job-id="@currentJobId"
                    data-finished="@(Model.IngestJobStatus is not null && IndexModel.IsFinished(Model.IngestJobStatus) ? "true" : "false")">
                    <div class="message-title">Обработка лекции</div>

                    <div>
                        <strong>Job UUID:</strong>
                        <code id="url-ingest-job-id">@currentJobId</code>
                    </div>

                    <div style="margin-top: 10px;">
                        <strong>Текущий статус:</strong>
                        <span id="url-ingest-status-text">
                            @(Model.IngestJobStatus is null ? Model.IngestStartResponse?.Status : Model.IngestJobStatus.Status)
                        </span>
                    </div>

                    <div style="margin-top: 10px;" id="url-ingest-message">
                        @(Model.IngestJobStatus is null ? "Задача поставлена в очередь." : IndexModel.BuildIngestStatusMessage(Model.IngestJobStatus))
                    </div>

                    <div style="margin-top: 10px;" id="url-ingest-final-note">
                        @if (Model.IngestJobStatus is not null && IndexModel.IsSucceeded(Model.IngestJobStatus))
                        {
                            <strong>Лекция добавлена. Теперь можно задавать вопросы.</strong>
                        }
                    </div>
                </div>
            }
        </section>

        <section class="panel glass-panel result-panel">
            <div class="panel-header">
                <h2>Задать вопрос</h2>
                <p>Вопрос будет задан по уже проиндексированным лекциям.</p>
            </div>

            <form method="post" asp-page-handler="Ask" class="ask-form" id="ask-form">
                <div class="field">
                    <label for="Question">Вопрос</label>
                    <textarea
                        id="Question"
                        name="Question"
                        rows="7"
                        placeholder="Например: какие основные темы объясняются в лекции?">@Model.Question</textarea>
                </div>

                <div class="params-grid">
                    <div class="field">
                        <label for="TopK">TopK</label>
                        <input id="TopK" name="TopK" value="@Model.TopK" type="number" min="1" max="20" />
                        <div class="hint">Сколько чанков взять из базы.</div>
                    </div>

                    <div class="field">
                        <label for="MinScore">MinScore</label>
                        <input id="MinScore" name="MinScore" value="@Model.MinScore.ToString(System.Globalization.CultureInfo.InvariantCulture)" type="text" inputmode="decimal" />
                        <div class="hint">Для проверки можно временно поставить 0. Используйте точку: 0.05.</div>
                    </div>
                </div>

                <div class="submit-row">
                    <button type="submit" id="submit-button" class="primary-btn">
                        <span class="btn-text">Спросить</span>
                    </button>
                </div>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.AskErrorMessage))
            {
                <div class="message-box message-error">
                    <div class="message-title">Ошибка</div>
                    <div>@Model.AskErrorMessage</div>
                </div>
            }

            @if (Model.AskResponse is not null)
            {
                @if (!Model.AskResponse.UsedContext)
                {
                    <div class="message-box message-warning">
                        <div class="message-title">Недостаточно контекста</div>
                        <div>
                            @(Model.AskResponse.Message ?? "Контекста недостаточно для уверенного ответа.")
                        </div>
                    </div>
                }

                <div class="answer-card">
                    <div class="answer-card-header">
                        <span class="answer-label">Generated answer</span>
                    </div>
                    <div class="answer-text">
                        @(Model.AskResponse.Answer ?? Model.AskResponse.Message ?? "Ответ не был сформирован.")
                    </div>
                </div>

                @if (Model.AskResponse.Sources.Count > 0)
                {
                    <div class="sources-section">
                        <div class="sources-title-row">
                            <h3>Источники</h3>
                            <span class="sources-count">@Model.AskResponse.Sources.Count</span>
                        </div>

                        <div class="sources-grid">
                            @foreach (var source in Model.AskResponse.Sources)
                            {
                                <div class="source-card">
                                    <div class="source-card-top">
                                        <div class="source-lecture">@source.LectureTitle</div>
                                        <div class="source-chip">Чанк #@source.ChunkIndex</div>
                                    </div>

                                    <div class="source-meta">
                                        <div class="meta-row">
                                            <span class="meta-label">Позиция</span>
                                            <span class="meta-value">@source.Position</span>
                                        </div>
                                        <div class="meta-row">
                                            <span class="meta-label">Примерная минута</span>
                                            <span class="meta-value">@source.ApproxMinute</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </section>
    </main>
</div>

<script>
(function () {
    const box = document.getElementById("url-ingest-status");
    if (!box) return;

    const jobId = box.dataset.jobId;
    if (!jobId || jobId === "00000000-0000-0000-0000-000000000000") return;

    if (box.dataset.finished === "true") return;

    const statusText = document.getElementById("url-ingest-status-text");
    const messageBox = document.getElementById("url-ingest-message");
    const finalNote = document.getElementById("url-ingest-final-note");

    let attempts = 0;
    const maxAttempts = 720;

    async function poll() {
        attempts++;

        try {
            const response = await fetch(`/?handler=IngestStatus&jobId=${encodeURIComponent(jobId)}`, {
                method: "GET",
                headers: {
                    "Accept": "application/json"
                }
            });

            if (!response.ok) return;

            const data = await response.json();

            if (!data.found) {
                if (messageBox) messageBox.textContent = data.message || "Задача не найдена.";
                return;
            }

            if (statusText) statusText.textContent = `${data.status}${data.stage ? " / " + data.stage : ""}`;
            if (messageBox) messageBox.textContent = data.message || "Обработка идёт.";

            if (data.canAskQuestions) {
                if (finalNote) {
                    finalNote.innerHTML = "<strong>Лекция добавлена. Теперь можно задавать вопросы.</strong>";
                }

                clearInterval(timer);
                return;
            }

            if (data.isFinished) {
                clearInterval(timer);
            }
        } catch {
            // Ignore transient polling errors.
        }

        if (attempts >= maxAttempts) {
            clearInterval(timer);
        }
    }

    const timer = setInterval(poll, 5000);
    poll();
})();
</script>
